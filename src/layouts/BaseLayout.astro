---
import BaseHead from '../components/BaseHead.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SearchModal from '../components/SearchModal.astro';
import '../styles/global.css';
interface Props { title: string; description: string; image?: string; }
const { title, description, image } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} />
    <script is:inline>
      // Pre-hydration theme to avoid flash. Order: explicit user choice → system preference → light.
      (function () {
        var stored = null;
        try { stored = localStorage.getItem('theme'); } catch (_) {}
        var sys = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        var t = stored === 'dark' || stored === 'light' ? stored : sys;
        document.documentElement.dataset.theme = t;
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <SiteHeader />
    <main id="main-content" tabindex="-1"><slot /></main>
    <SiteFooter />
    <SearchModal />
    <script is:inline>
      // Heading-anchor click → copy canonical URL to clipboard.
      // rehype-autolink-headings only inserts the <a>; this is what makes the click "copy a permalink".
      document.addEventListener('click', (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;
        const a = target.closest('a.heading-anchor');
        if (!a) return;
        e.preventDefault();
        const hash = a.getAttribute('href') || '';
        const url = window.location.origin + window.location.pathname + hash;
        navigator.clipboard?.writeText(url).catch(() => {});
        history.replaceState(null, '', hash);
        a.setAttribute('data-copied', '1');
        setTimeout(() => a.removeAttribute('data-copied'), 1200);
      });
    </script>
  </body>
</html>
