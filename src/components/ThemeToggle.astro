---
---
<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle color theme"
  aria-pressed="false"
  title="Toggle color theme"
>
  <span data-theme-icon="light" aria-hidden="true">☀</span>
  <span data-theme-icon="dark" aria-hidden="true">☾</span>
</button>
<script is:inline>
  (() => {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    const sync = () => {
      const isDark = document.documentElement.dataset.theme === 'dark';
      btn.setAttribute('aria-pressed', isDark ? 'true' : 'false');
    };
    const apply = (t) => {
      document.documentElement.dataset.theme = t;
      try { localStorage.setItem('theme', t); } catch (_) {}
      sync();
    };
    sync();
    btn.addEventListener('click', () => {
      const current = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
      apply(current === 'dark' ? 'light' : 'dark');
    });
    // Respect system preference changes if user hasn't picked manually
    const mq = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)');
    if (mq && mq.addEventListener) {
      mq.addEventListener('change', (e) => {
        let stored = null;
        try { stored = localStorage.getItem('theme'); } catch (_) {}
        if (stored !== 'dark' && stored !== 'light') {
          apply(e.matches ? 'dark' : 'light');
        }
      });
    }
  })();
</script>
<style>
  #theme-toggle [data-theme-icon='dark'] { display: none; }
  :root[data-theme='dark'] #theme-toggle [data-theme-icon='light'] { display: none; }
  :root[data-theme='dark'] #theme-toggle [data-theme-icon='dark'] { display: inline; }
</style>
