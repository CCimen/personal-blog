---
import type { CollectionEntry } from 'astro:content';
import type { TopicSlug } from '../config/topics';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TopicChip from '../components/TopicChip.astro';
import MaturityBadge from '../components/MaturityBadge.astro';
import CopyLinkButton from '../components/CopyLinkButton.astro';
import RelatedSection from '../components/RelatedSection.astro';

interface Props {
  entry: CollectionEntry<'writing'>;
}
const { entry } = Astro.props;
const topics = (entry.data.topics ?? []) as TopicSlug[];
---
<BaseLayout title={entry.data.title} description={entry.data.description}>
  <header class="article-header">
    <h1>{entry.data.title}</h1>
    <p class="article-lede">{entry.data.description}</p>
    <div class="article-meta">
      <FormattedDate date={entry.data.pubDate} />
      {entry.data.maturity && <MaturityBadge level={entry.data.maturity} />}
      <CopyLinkButton />
    </div>
    {topics.length > 0 && (
      <div class="topic-chips">
        {topics.map((t) => <TopicChip topic={t} />)}
      </div>
    )}
  </header>
  <article class="prose"><slot /></article>
  <RelatedSection refs={entry.data.related} />
</BaseLayout>
