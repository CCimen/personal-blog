---
import type { CollectionEntry } from 'astro:content';
import type { TopicSlug } from '../config/topics';
import { entryHref } from '../lib/collections';
import TopicChip from './TopicChip.astro';
import MaturityBadge from './MaturityBadge.astro';

interface Props {
  entry: CollectionEntry<'guides'>;
}
const { entry } = Astro.props;
const topics = (entry.data.topics ?? []) as TopicSlug[];
---
<article class="card">
  <h3 class="card-title">
    <a class="card-link" href={entryHref(entry)}>{entry.data.title}</a>
  </h3>
  <p>{entry.data.description}</p>
  <div class="card-meta">
    {entry.data.category && <span>{entry.data.category}</span>}
    {entry.data.maturity && <MaturityBadge level={entry.data.maturity} />}
  </div>
  {topics.length > 0 && (
    <div class="topic-chips">
      {topics.map((t) => <TopicChip topic={t} />)}
    </div>
  )}
</article>
