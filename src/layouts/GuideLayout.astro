---
import { getCollection, type CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import { entryHref, entrySlug, published } from '../lib/collections';

interface Props {
  entry: CollectionEntry<'guides'>;
  headings: MarkdownHeading[];
}
const { entry, headings } = Astro.props;

const all = published(await getCollection('guides'));

// Group by category, preserving first-seen order; uncategorized entries under "Guides".
const groups = new Map<string, CollectionEntry<'guides'>[]>();
for (const g of all) {
  const cat = g.data.category ?? 'Guides';
  const list = groups.get(cat) ?? [];
  list.push(g);
  groups.set(cat, list);
}
// Sort each group by `order` asc (undefined last), then by title.
for (const list of groups.values()) {
  list.sort((a, b) => {
    const ao = a.data.order ?? Number.POSITIVE_INFINITY;
    const bo = b.data.order ?? Number.POSITIVE_INFINITY;
    if (ao !== bo) return ao - bo;
    return a.data.title.localeCompare(b.data.title);
  });
}

const currentSlug = entrySlug(entry);
---
<BaseLayout title={entry.data.title} description={entry.data.description}>
  <div class="guide-grid">
    <aside class="guide-sidebar">
      {[...groups.entries()].map(([category, items]) => (
        <section>
          <h3>{category}</h3>
          <ul>
            {items.map((g) => (
              <li>
                <a
                  href={entryHref(g)}
                  data-active={entrySlug(g) === currentSlug ? 'true' : 'false'}
                >
                  {g.data.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </aside>
    <article class="prose">
      <h1>{entry.data.title}</h1>
      <slot />
    </article>
    <aside class="guide-toc">
      <h3>On this page</h3>
      <ol>
        {headings.filter((h) => h.depth >= 2 && h.depth <= 3).map((h) => (
          <li data-depth={h.depth}><a href={`#${h.slug}`}>{h.text}</a></li>
        ))}
      </ol>
    </aside>
  </div>
</BaseLayout>
