---
import { getCollection, render } from 'astro:content';
import WritingLayout from '../../layouts/WritingLayout.astro';
import { entrySlug, published } from '../../lib/collections';

export async function getStaticPaths() {
  const entries = published(await getCollection('writing'));
  return entries.map((entry) => ({
    params: { slug: entrySlug(entry) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<WritingLayout entry={entry}>
  <Content />
</WritingLayout>
