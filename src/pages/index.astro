---
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryCard from '../components/EntryCard.astro';
import EntryRow from '../components/EntryRow.astro';
import TopicLinkCard from '../components/TopicLinkCard.astro';
import { byNewest, byPinnedOrder, getAllPublishedEntries } from '../lib/collections';
import { TOPIC_SLUGS } from '../config/topics';

const allPublished = await getAllPublishedEntries();

const pinned = byPinnedOrder(
  allPublished.filter((e) => (e.data as any).pinned === true),
);

const writing = allPublished.filter((e) => e.collection === 'writing');
const recentWriting = byNewest(writing).slice(0, 5);

const projects = allPublished.filter((e) => e.collection === 'projects');
const selectedProjects = byNewest(projects.filter((e) => (e.data as any).featured === true)).slice(0, 3);
---
<BaseLayout
  title="Çagri Cimen"
  description="Essays, notes, guides, and projects — learning in public about AI coding, models, and team practices."
>
  <section class="home-hero">
    <h1>Çagri Cimen</h1>
    <p class="home-tagline">Engineer building with AI tools, writing about what I learn.</p>
    <p class="home-intro">
      I lead engineering teams and ship things with AI-assisted workflows. This site is where I
      keep my notes, essays, guides, and projects — a working record of what I try, what sticks,
      and what I'd do differently next time.
    </p>
  </section>

  {pinned.length > 0 && (
    <section class="home-section">
      <div class="home-section-head">
        <h2>Pinned</h2>
      </div>
      <div class="card-grid">
        {pinned.map((entry) => <EntryCard entry={entry} />)}
      </div>
    </section>
  )}

  {recentWriting.length > 0 && (
    <section class="home-section">
      <div class="home-section-head">
        <h2>Recent writing</h2>
        <a href="/writing/">All writing →</a>
      </div>
      <ul class="entry-list">
        {recentWriting.map((entry) => (
          <li><EntryRow entry={entry} /></li>
        ))}
      </ul>
    </section>
  )}

  <section class="home-section">
    <div class="home-section-head">
      <h2>Topics</h2>
      <a href="/topics/">All topics →</a>
    </div>
    <div class="topic-grid">
      {TOPIC_SLUGS.map((slug) => (
        <TopicLinkCard topic={slug} />
      ))}
    </div>
  </section>

  {selectedProjects.length > 0 && (
    <section class="home-section">
      <div class="home-section-head">
        <h2>Selected projects</h2>
        <a href="/projects/">All projects →</a>
      </div>
      <ul class="entry-list">
        {selectedProjects.map((entry) => (
          <li><EntryRow entry={entry} /></li>
        ))}
      </ul>
    </section>
  )}

  <section class="home-cta">
    <p>
      Want more? Read the <a href="/writing/">writing archive</a> or find out
      <a href="/about/">more about me</a>.
    </p>
  </section>
</BaseLayout>
