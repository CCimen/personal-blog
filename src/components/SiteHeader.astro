---
import ThemeToggle from './ThemeToggle.astro';

const path = Astro.url.pathname;
const isActive = (prefix: string) =>
  prefix === '/' ? path === '/' : path.startsWith(prefix);

const navLinks = [
  { href: '/writing/', label: 'Writing' },
  { href: '/notes/', label: 'Notes' },
  { href: '/topics/', label: 'Topics' },
  { href: '/guides/', label: 'Guides' },
  { href: '/projects/', label: 'Projects' },
  { href: '/about/', label: 'About' },
] as const;
---
<header class="site-header">
  <a href="/" class="brand" aria-current={isActive('/') ? 'page' : undefined}>
    Çagri Cimen
  </a>
  <nav class="primary-nav" aria-label="Primary">
    {navLinks.map(({ href, label }) => (
      <a href={href} aria-current={isActive(href) ? 'page' : undefined}>{label}</a>
    ))}
  </nav>
  <div class="header-actions">
    <button id="search-trigger" type="button" aria-label="Search the site (Cmd+K)">
      <span>Search</span>
      <kbd aria-hidden="true">⌘K</kbd>
    </button>
    <ThemeToggle />
  </div>
</header>
