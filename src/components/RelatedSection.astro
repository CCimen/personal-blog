---
import { resolveRelated } from '../lib/related';
import EntryRow from './EntryRow.astro';

interface Props {
  refs: string[];
}
const { refs } = Astro.props;
const entries = refs && refs.length > 0 ? await resolveRelated(refs) : [];
---
{entries.length > 0 && (
  <aside class="related-section">
    <h2>Related</h2>
    <ul class="entry-list related-entry-list">
      {entries.map((entry) => (
        <li><EntryRow entry={entry} /></li>
      ))}
    </ul>
  </aside>
)}
