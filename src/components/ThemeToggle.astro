---
---
<button id="theme-toggle" type="button" aria-label="Toggle color theme">
  <span data-theme-icon="light" aria-hidden="true">☀</span>
  <span data-theme-icon="dark" aria-hidden="true">☾</span>
</button>
<script is:inline>
  (() => {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    const apply = (t) => {
      document.documentElement.dataset.theme = t;
      localStorage.setItem('theme', t);
    };
    btn.addEventListener('click', () => {
      const current = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
      apply(current === 'dark' ? 'light' : 'dark');
    });
  })();
</script>
<style>
  #theme-toggle [data-theme-icon='dark'] { display: none; }
  :root[data-theme='dark'] #theme-toggle [data-theme-icon='light'] { display: none; }
  :root[data-theme='dark'] #theme-toggle [data-theme-icon='dark'] { display: inline; }
</style>
